# Committed template. Copy to .env (gitignored) and fill in real values:
#   cp .env.example .env
#
# docker-compose.yml loads this file straight into the container's environment via `env_file:`.
# Anything you define here becomes available as "${VAR_NAME}" in mcp-servers.json headers and
# llm-models.json's apiKey field (expanded at connect/model-load time — see
# src/config/EnvExpansion.cs). Only define what you actually reference; a "${VAR}" used in a
# config file that isn't set here fails startup with a clear error rather than sending an empty
# credential.
#
# NEVER paste real values here into chat, commit them, or share this file — .env is gitignored
# for exactly that reason.

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GITHUB_MCP_PAT=ghp_your-github-token-here

# Uncomment for wire-level LLM debug logging -> logs/{sessionId|runId}.log
# MCPHOST_LLM_DEBUG=1
